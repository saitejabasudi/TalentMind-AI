{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm --filter @workspace/talentmind run build",
  "outputDirectory": "artifacts/talentmind/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.ts": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
